# =========================================================================
# CONDUCTOR (the router) — deploy as its own attested app.
# =========================================================================

# Enclave-bound signing key, injected by the EigenCompute KMS at runtime.
# Do NOT set it yourself. Signs every routing receipt.
# MNEMONIC=

# --- PUBLIC (attested, visible on dashboard) ---

# Registry: model_id -> the attested worker that serves it. Every model any
# band can choose must appear here, or boot fails.
WORKERS_PUBLIC={"openai/gpt-4o-mini":"https://worker-mini.example.xyz","openai/gpt-4o":"https://worker-4o.example.xyz","anthropic/claude-3.7-sonnet":"https://worker-claude.example.xyz"}

# Routing policy. policy_hash = keccak256(canonical({bands, params})) — hashed
# into every receipt so the decision is checkable.
ROUTING_RECIPE_PUBLIC={"bands":{"low":{"looper":"single","models":["openai/gpt-4o-mini"]},"med":{"looper":"single","models":["openai/gpt-4o"]},"high":{"looper":"confidence","models":["openai/gpt-4o","anthropic/claude-3.7-sonnet"]}},"params":{"confidence_threshold":0.5,"remom_rounds":2}}

ROUTER_VERSION_PUBLIC=1.0.0
# IMAGE_DIGEST_PUBLIC=          # conductor's own RTMR digest, if surfaced at runtime


# =========================================================================
# WORKER — deploy one per model (each in its OWN enclave, its OWN key).
# Same image, run with CMD `node dist/worker/index.js`.
# =========================================================================

# --- SEALED (never _PUBLIC) ---
# MNEMONIC=                     # the worker's own enclave-bound key (KMS-injected)
MODEL_API_KEY=                  # only for the "openai" backend; sealed

# --- PUBLIC ---
MODEL_IDS_PUBLIC=openai/gpt-4o-mini      # comma-separated model ids this worker serves
WORKER_BACKEND_PUBLIC=echo               # "echo" (deterministic dev/CI) | "openai" (proxy a real API, still signs)
MODEL_API_BASE_PUBLIC=https://openrouter.ai/api/v1   # openai backend only
# IMAGE_DIGEST_PUBLIC=          # worker's own RTMR digest

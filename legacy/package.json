{
  "name": "attested-router",
  "version": "1.0.0",
  "private": true,
  "description": "Attested vLLM-style semantic router — signs a routing receipt for every request inside an Intel TDX enclave.",
  "type": "module",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "ethers": "6.13.4",
    "express": "4.21.1",
    "ses": "1.10.0",
    "typescript": "5.6.3"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.17.6",
    "tsx": "4.19.2"
  }
}

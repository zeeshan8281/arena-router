# Copy to .env (gitignored) and fill in. Run local commands with Node's native loader:
#   node --env-file=.env competition/runner.mjs --type baseline --author _baseline
#   node --env-file=.env kit/arena.mjs smoke --trials 1
#
# For CI, these same secrets live in the GitHub `eval-runner` environment (spec §3),
# NOT in this file. See docs/SECRETS.md for which goes where.

# ── OpenRouter (WP3 pipeline, WP11 baseline probe) ──
# Management/provisioning key — mints capped per-run keys, cannot itself do inference.
# The account behind it MUST have a credit balance (probe + runs spend real dollars).
OPENROUTER_MANAGEMENT_KEY=

# Your own inference key — used by `arena smoke` for LOCAL iteration (not CI).
OPENROUTER_API_KEY=

# ── Anthropic (WP5 judge, D13) ──
# Claude Sonnet 4.6, deliberately off the competition model pool.
ANTHROPIC_API_KEY=

# ── Hetzner eval box (WP7) — reference; these are used ON the box / by CI, not local runs ──
# Self-hosted runner registration token (repo → Settings → Actions → Runners → New).
GH_RUNNER_TOKEN=
GH_REPO_URL=https://github.com/zeeshan8281/arena-router
# SSH target for provisioning the box (infra/runner-setup.md).
EVAL_BOX_SSH=root@<box-ip>

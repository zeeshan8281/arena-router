{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zeeshan8281/arena-router/results/schema/run.schema.json",
  "title": "Arena run result",
  "description": "Per-run results file (spec §7.1). Emitted by competition/scoring/results.mjs buildRunResult().",
  "type": "object",
  "required": ["schema_version", "run_id", "run_type", "author", "trials", "median_pass_count", "median_billed_usd", "validity"],
  "additionalProperties": false,
  "$defs": {
    "flag": {
      "type": "object",
      "description": "Integrity/anomaly flag emitted by scoring/integrity.mjs.",
      "required": ["severity", "type"],
      "additionalProperties": false,
      "properties": {
        "severity": { "enum": ["void", "review"] },
        "type": { "type": "string", "description": "byok | free-variant | off-allowlist | low-token-pass | …" },
        "detail": { "type": "string" },
        "task": { "type": "string" },
        "tokens": { "type": "number", "minimum": 0 }
      }
    }
  },
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string", "description": "pr<n>-<smoke|full|baseline>-a<attempt>" },
    "run_type": { "enum": ["smoke", "full", "baseline"] },
    "pr": { "type": ["integer", "string", "null"] },
    "author": { "type": "string" },
    "entry_name": { "type": ["string", "null"] },
    "submission_sha": { "type": ["string", "null"] },
    "pi_version": { "type": ["string", "null"] },
    "config_sha": { "type": ["string", "null"] },
    "started_at": { "type": ["string", "null"] },
    "finished_at": { "type": ["string", "null"] },
    "trials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pass_count", "billed_usd"],
        "additionalProperties": false,
        "properties": {
          "pass_vector": { "type": "object", "additionalProperties": { "type": "boolean" } },
          "pass_count": { "type": "integer", "minimum": 0 },
          "n_errors": { "type": "integer", "minimum": 0 },
          "billed_usd": { "type": "number", "minimum": 0, "description": "OpenRouter ledger delta for this trial" },
          "generation_ids": { "type": "array", "items": { "type": "string" }, "description": "ledger audit trail (§7.1)" },
          "input_tokens": { "type": "integer", "minimum": 0 },
          "output_tokens": { "type": "integer", "minimum": 0 },
          "cache_read_tokens": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "median_pass_count": { "type": "number", "minimum": 0 },
    "median_billed_usd": { "type": "number", "minimum": 0 },
    "openrouter_key_name": { "type": "string", "description": "the minted key's name; equals run_id" },
    "validity": {
      "type": "object",
      "required": ["voided"],
      "additionalProperties": false,
      "properties": {
        "byok_zero": { "type": "boolean", "description": "byok_usage == 0 (§6.1.6)" },
        "models_allowlisted": { "type": "boolean", "description": "every generation record's model ∈ allowlist" },
        "post_teardown_records": { "type": "boolean", "description": "late records after key deletion (§6.1.7)" },
        "voided": { "type": "boolean" },
        "void_reason": {
          "description": "null when valid; a string for pre-run gates (e.g. monthly-budget-exhausted); the integrity flag list when integrity voided the run.",
          "oneOf": [
            { "type": "null" },
            { "type": "string" },
            { "type": "array", "items": { "$ref": "#/$defs/flag" } }
          ]
        }
      }
    },
    "anomaly_flags": { "type": "array", "items": { "$ref": "#/$defs/flag" } },
    "smoke_gate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pass": { "type": "boolean" },
        "median_pass": { "type": "number", "minimum": 0 },
        "threshold": { "type": "number" }
      }
    }
  }
}
